# Veritas Backend Environment Variables
# Copy to .env and adjust for your deployment

# Database (SQLite file path — must be on a persistent volume)
# VERITAS_DATABASE_URL=sqlite:////app/data/veritas.db

# Content-addressed storage directory (must be on a persistent volume)
# VERITAS_STORAGE_DIR=/app/data/store

# CORS origins — add your Vercel frontend URL as a JSON array
# VERITAS_CORS_ORIGINS=["https://your-app.vercel.app","https://yourdomain.com"]

# OpenTimestamps external anchoring
# VERITAS_TIMESTAMP_ENABLED=true
# VERITAS_TIMESTAMP_DIR=/app/data/timestamps
# VERITAS_TIMESTAMP_CALENDARS=["https://alice.btc.calendar.opentimestamps.org","https://bob.btc.calendar.opentimestamps.org","https://finney.calendar.eternitywall.com"]
# VERITAS_TIMESTAMP_BITCOIN_URL=https://blockstream.info/api

# RFC 3161 trusted timestamp authority (FreeTSA by default)
# VERITAS_RFC3161_ENABLED=true
# VERITAS_RFC3161_TSA_URL=https://freetsa.org/tsr
# VERITAS_RFC3161_TSA_CERT_URL=https://freetsa.org/files/tsa.crt

# Max upload size in MB
# VERITAS_MAX_UPLOAD_MB=512

# URL collector settings
# VERITAS_COLLECT_TIMEOUT_SECONDS=30.0
# VERITAS_COLLECT_MAX_REDIRECTS=5
# VERITAS_ALLOW_PRIVATE_COLLECT=false

# Batch/crawl limits
# VERITAS_COLLECT_BATCH_LIMIT=50
# VERITAS_DEFAULT_COLLECTOR=
